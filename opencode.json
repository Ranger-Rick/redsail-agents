{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "product-manager",
  "agent": {
    "developer": {
      "mode": "subagent",
      "model": "github-copilot/gpt-5.3-codex",
      "permission": {
        "edit": "allow",
        "bash": "allow"
      },
      "prompt": "{file:./.opencode/agents/developer.md}"
    },
    "product-manager": {
      "mode": "primary",
      "model": "github-copilot/claude-opus-4.5",
      "permission": {
        "edit": "deny",
        "bash": "deny"
      },
      "prompt": "{file:./.opencode/agents/product-manager.md}"
    },
    "pioneerrx-business-expert": {
      "mode": "subagent",
      "model": "github-copilot/gpt-5.3-codex",
      "permission": {
        "edit": "deny",
        "bash": "deny"
      },
      "prompt": "{file:./.opencode/agents/pioneerrx-business-expert.md}"
    },
    "pioneerrx-code-expert": {
      "mode": "subagent",
      "model": "github-copilot/gpt-5.3-codex",
      "permission": {
        "edit": "deny",
        "bash": "allow"
      },
      "prompt": "{file:./.opencode/agents/pioneerrx-code-expert.md}"
    },
    "technical-writer": {
      "mode": "subagent",
      "model": "github-copilot/gpt-5.3-codex",
      "permission": {
        "edit": "allow",
        "bash": "deny"
      },
      "prompt": "{file:./.opencode/agents/technical-writer.md}"
    },
    "tester": {
      "mode": "subagent",
      "model": "github-copilot/gpt-5.3-codex",
      "permission": {
        "edit": "allow",
        "bash": "allow"
      },
      "prompt": "{file:./.opencode/agents/tester.md}"
    },
    "tony-stark": {
      "mode": "subagent",
      "model": "github-copilot/claude-opus-4.5",
      "temperature": 0.9,
      "permission": {
        "edit": "deny",
        "bash": "deny"
      },
      "prompt": "{file:./.opencode/agents/tony-stark.md}"
    }
  }
}
